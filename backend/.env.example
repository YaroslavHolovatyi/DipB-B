# ------------------------------------------------------------------------------
# Beer & Beverages — backend environment template.
# Copy to `.env` and fill in the secrets. The file is .gitignore'd.
# ------------------------------------------------------------------------------

# --- App ----------------------------------------------------------------------
APP_ENV=local                  # local | staging | production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# JSON array of allowed origins for CORS (pydantic-settings 2.6+ requires JSON for list fields).
CORS_ALLOW_ORIGINS=["http://localhost:8081","http://localhost:19006","exp://127.0.0.1:19000"]

# --- Database (matches docker-compose.yml service `postgres`) ------------------
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/beer_and_beverages
# Sync URL Alembic uses (same DSN with psycopg-style driver).
DATABASE_SYNC_URL=postgresql+psycopg://app:app@localhost:5432/beer_and_beverages

# --- Redis (matches docker-compose.yml service `redis`) ------------------------
REDIS_URL=redis://localhost:6379/0

# --- JWT ----------------------------------------------------------------------
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=replace-me-with-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_MIN=15
JWT_REFRESH_TOKEN_TTL_DAYS=30

# --- OpenAI (receipt OCR + Tavern Tales) ---------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL_VISION=gpt-4o
OPENAI_MODEL_CHAT=gpt-4o

# --- Object storage (S3 / Cloudflare R2) ---------------------------------------
S3_ENDPOINT_URL=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
